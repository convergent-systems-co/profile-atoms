---
const { profile } = Astro.props;
const slug = profile.canonical_name.replace(/\//g, "-");
const href = `/profiles/${slug}/`;
const rolePackCount = profile.role_packs?.length ?? 0;
const policyCount = profile.policy_stack?.length ?? 0;
const govCount = profile.governance_stack?.length ?? 0;
const identityCount = profile.available_identities?.length ?? 0;
const channelCount = profile.available_channels?.length ?? 0;
const knowledgeCount = profile.knowledge_sources?.length ?? 0;
const workflowCount = profile.default_workflows?.length ?? 0;
---
<article style="border: 1px solid var(--border); border-radius: 0.5rem; padding: 1rem; background: var(--card); display: flex; flex-direction: column; gap: 0.75rem;">
  <header style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;">
    <h3 style="margin: 0;"><a href={href}>{profile.canonical_name}</a></h3>
    <code style="color: var(--muted); font-size: 0.75rem;">v{profile.version}</code>
  </header>
  <p style="margin: 0; color: var(--muted); font-size: 0.9rem; line-height: 1.4;">{profile.description}</p>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr)); gap: 0.5rem 1rem; font-size: 0.8rem; padding-top: 0.5rem; border-top: 1px dashed var(--border);">
    <span><strong>{rolePackCount}</strong> role-packs</span>
    <span><strong>{policyCount}</strong> policies</span>
    <span><strong>{govCount}</strong> governance</span>
    <span><strong>{identityCount}</strong> identities</span>
    <span><strong>{channelCount}</strong> channels</span>
    <span><strong>{knowledgeCount}</strong> knowledge</span>
    <span><strong>{workflowCount}</strong> workflows</span>
  </div>
  <div style="font-size: 0.75rem; color: var(--muted);">
    Authored by: <code>{profile.authored_by}</code>
  </div>
</article>
