---
const { title, description } = Astro.props;
const siteTitle = title ? `${title} · PROFILE-Atoms` : "PROFILE-Atoms";
const siteDesc = description ?? "User/agent profile compositions — durable working-identity declarations for the Olympus broker.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/favicon.svg" />
    <link rel="preconnect" href="https://brand-atoms.com" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/css/tokens.css" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/ui/atoms-catalog.css" />
    <style is:global>
      body { min-height: 100vh; }
      .hero-mark { width: 160px; height: 160px; margin-bottom: 20px; object-fit: contain; }
      .sidenav-wordmark { width: 140px; object-fit: contain; display: block; }
      code { background: var(--kbd, #f0f0f0); padding: 0.125rem 0.25rem; border-radius: 0.25rem; font-size: 0.9em; }
      pre { background: var(--kbd, #f0f0f0); padding: 1rem; border-radius: 0.5rem; overflow-x: auto; }
      h1, h2, h3 { line-height: 1.2; }
      .markdown h1, .markdown h2, .markdown h3 { margin-top: 2rem; }
      .markdown blockquote { border-left: 3px solid var(--accent); padding-left: 1rem; margin-left: 0; color: var(--muted); }
      .markdown table { border-collapse: collapse; margin: 1rem 0; }
      .markdown th, .markdown td { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
      .markdown th { background: var(--kbd, #f0f0f0); }
    </style>
  </head>
  <body>
    <div class="shell">
      <main class="content">
        <slot />
        <footer>
          Part of the <a href="https://github.com/convergent-systems-co/atoms">atoms ecosystem</a>. Apache-2.0.
        </footer>
      </main>
      <nav class="sidenav">
        <a class="brand" href="/">
          <img src="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/atom-family-wordmark.png" alt="ATOMS" class="sidenav-wordmark" />
        </a>
        <div class="aside-nav">
          <a href="/profiles/">Profiles</a>
          <a href="/design/">Design</a>
          <a href="/how-to-use/">How to use</a>
        </div>
        <div class="aside-meta">
          <a class="meta-link" href="https://github.com/convergent-systems-co/profile-atoms">github ↗</a>
          <a class="meta-link" href="https://atoms.convergent-systems.com">atoms directory ↗</a>
        </div>
      </nav>
    </div>
  </body>
</html>
